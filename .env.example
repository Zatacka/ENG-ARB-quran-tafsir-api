# Comma-separated website origins. Use your real domains in production.
ALLOWED_ORIGINS=https://example.com,https://www.example.com

# Optional. When set, clients must send this value in the X-API-Key header.
API_KEY=

CACHE_CONTROL=public, max-age=300, stale-while-revalidate=86400

# Normally unnecessary. The default is ./data.
# TAFSIR_DATA_DIR=/absolute/path/to/data
